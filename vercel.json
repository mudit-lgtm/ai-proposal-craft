{
  "installCommand": "pnpm install --no-frozen-lockfile && cd api && npm install --production",
  "buildCommand": "pnpm --filter @workspace/proposal-craft run build",
  "outputDirectory": "artifacts/proposal-craft/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
